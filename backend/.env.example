# Copia este archivo como ".env" y rellena tus valores reales.
# El archivo ".env" NO se sube a Git (está en .gitignore).

# Proveedor de Grok. Por defecto OpenRouter (https://openrouter.ai/keys).
# Alternativa: xAI directo -> GROK_BASE_URL=https://api.x.ai/v1 (https://console.x.ai)
GROK_BASE_URL=https://openrouter.ai/api/v1

# API key del proveedor que uses (OpenRouter: sk-or-...  /  xAI: xai-...)
GROK_API_KEY=tu_api_key_aqui

# Modelo a usar (OpenRouter: x-ai/grok-4.3  /  xAI directo: grok-4.3)
# Nota: el slug grok-beta fue retirado por xAI el 15 de mayo de 2026.
GROK_MODEL=x-ai/grok-4.3

# Puerto del backend
PORT=3001
